{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SmartAccountant",
  "version": "0.1.0",
  "identifier": "com.smartaccountant.app",
  "build": {
    "devUrl": "https://your-smart-accountant.lovable.app",
    "frontendDist": "https://your-smart-accountant.lovable.app"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Smart Accountant",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "url": "https://your-smart-accountant.lovable.app"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
